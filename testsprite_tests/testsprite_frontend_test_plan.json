[
  {
    "id": "TC001",
    "title": "Create a new visible product with multiple image URLs (up to 5)",
    "description": "Verifies a vendor can create a product with multiple image URLs, enable visibility, and see it listed after saving.",
    "category": "Product Management (CRUD, Multi-image, Soft Delete)",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"aitbenalihoucine18@gmail.com\" into the email/username field"
      },
      {
        "type": "action",
        "description": "Type \"Houcine18\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Log in\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/dashboard\""
      },
      {
        "type": "action",
        "description": "Click on \"Products\" in the dashboard navigation"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/dashboard/products\""
      },
      {
        "type": "action",
        "description": "Click the \"Add Product\" button"
      },
      {
        "type": "action",
        "description": "Type \"Argan Oil Soap\" into the \"Name\" field"
      },
      {
        "type": "action",
        "description": "Type \"35\" into the \"Price\" field"
      },
      {
        "type": "action",
        "description": "Type \"12\" into the \"Stock\" field"
      },
      {
        "type": "action",
        "description": "Type \"https://example.com/img1.jpg\" into the first image URL field"
      },
      {
        "type": "action",
        "description": "Type \"https://example.com/img2.jpg\" into the second image URL field"
      },
      {
        "type": "action",
        "description": "Type \"https://example.com/img3.jpg\" into the third image URL field"
      },
      {
        "type": "action",
        "description": "Type \"https://example.com/img4.jpg\" into the fourth image URL field"
      },
      {
        "type": "action",
        "description": "Type \"https://example.com/img5.jpg\" into the fifth image URL field"
      },
      {
        "type": "action",
        "description": "Click the \"Visibility\" toggle to set it ON"
      },
      {
        "type": "action",
        "description": "Click the \"Save Product\" button"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Argan Oil Soap\" is visible"
      }
    ]
  },
